{
  "buildCommand": "",
  "devCommand": "",
  "installCommand": "",
  "framework": null,
  "public": true,
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/chat.js": {
      "maxDuration": 30
    },
    "api/lead-bot.js": {
      "maxDuration": 30
    }
  },
  "redirects": [
    {
      "source": "/code.html",
      "destination": "/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/chat",
      "destination": "/api/chat.js"
    },
    {
      "source": "/api/lead-bot",
      "destination": "/api/lead-bot.js"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, X-Lead-Token, X-Idempotency-Key" }
      ]
    }
  ]
}
